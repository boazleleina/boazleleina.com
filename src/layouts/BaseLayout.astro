---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import { ViewTransitions } from "astro:transitions";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  sideBarActiveItemID,
  ogType,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="lofi">
  <head>
    <BaseHead title={title} description={description} image={image} , ogType={ogType} />
    {TRANSITION_API && <ViewTransitions />}
    <script is:inline>
      // Blocking script to prevent Flash of Un-themed Content (FOUC)
      const theme = localStorage.getItem('theme') || 'lofi';
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <div class="bg-base-100 drawer lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content bg-base-100">
        <Header title={SITE_TITLE} />
        <div class="md:flex md:justify-center">
          <main class="p-6 pt-10 lg:max-w-[900px] max-w-[100vw]">
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
    </div>

    <script is:inline>
      // Interactive script to toggle theme and sync all slider toggles
      const applyTheme = (theme) => {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        
        // Update all toggle checkboxes on the page
        const toggles = document.querySelectorAll('input.theme-toggle-btn');
        toggles.forEach(toggle => {
          toggle.checked = (theme === 'dark');
        });
      };

      const setupTheme = () => {
        const currentTheme = localStorage.getItem('theme') || 'lofi';
        applyTheme(currentTheme);

        document.querySelectorAll('input.theme-toggle-btn').forEach(toggle => {
          // Remove old listeners to avoid stacking them during page transitions
          const newToggle = toggle.cloneNode(true);
          toggle.parentNode.replaceChild(newToggle, toggle);

          newToggle.addEventListener('change', (e) => {
            const newTheme = e.target.checked ? 'dark' : 'lofi';
            applyTheme(newTheme);
          });
        });
      };

      // Run on initial load
      setupTheme();

      // Run on ViewTransitions page swaps
      document.addEventListener('astro:after-swap', setupTheme);
    </script>
  </body>
</html>
