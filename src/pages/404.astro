---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
---

<BaseLayout title="404: Not Found" includeSidebar={false}>
  <div class="text-center flex flex-col items-center justify-center">
    <div class="w-48 h-48 mb-6 block m-auto">
      <Image class="rounded-full shadow-lg object-cover w-full h-full" width={300} height={300} src="/avatar.webp" alt="Not Found Avatar" />
    </div>
    <h1 class="text-9xl font-bold mb-2">404</h1>
    <h3 class="text-2xl font-bold mb-3">Whoops, the cows ate my page 🐄</h3>
    <a class="btn btn-accent mt-9" href="/">Home</a>
  </div>
</BaseLayout>
